<script>
  (function () {
    const hostname = window.location.hostname.toLowerCase();

    // Only run on root path
    if (window.location.pathname !== '/') return;

    // Do nothing if hostname contains "weslack"
    if (hostname.includes('we')) return;
    if (hostname.includes('slack')) return;
    if (hostname.includes('hief')) return;

    let host = hostname;

    // Remove leading www
    if (host.startsWith('www.')) {
      host = host.slice(4);
    }

    const parts = host.split('.');

    // Remove final TLD only
    if (parts.length > 1) {
        parts.pop();
    }

    const title = parts
      .map(part =>
        part
          .replace(/-/g, ' ')
          .replace(/\b\w/g, c => c.toUpperCase())
      )
      .join(' ');

    document.title = title;
    window._title = title;
  })();
</script>



